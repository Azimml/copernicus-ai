OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

SITE_ROOT=https://copernicusberlin.org
CRAWL_PATHS=/en
CRAWL_EXCLUDE_HOSTS=campus.copernicusberlin.org
CRAWL_MAX_PAGES=200
CRAWL_TIMEOUT_SEC=30
CRAWL_RENDER_WAIT_MS=2500

RETRIEVAL_TOP_K=8
RETRIEVAL_MAX_CONTEXT_CHARS=8000

ADMIN_TOKEN=change-me

# Optional: override the SQLite database location (default: data/copernicus.db)
# COPERNICUS_DB_PATH=/var/lib/copernicus/copernicus.db

# --- SMTP (operator replies to support requests) ---
# Leave SMTP_HOST empty to disable email; replies will still be logged but
# nothing will be delivered.
#
# Gmail example (App Passwords required, NOT your account password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@yourdomain.com
#   SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
#   SMTP_USE_TLS=true
#
# Mailgun / SendGrid / Postmark — use the credentials from your dashboard.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=
SMTP_FROM_NAME=Copernicus Berlin
SMTP_REPLY_TO=

SOCIAL_LINK_DOMAINS=https://www.instagram.com/,https://www.linkedin.com/,https://www.youtube.com/,https://t.me/,https://x.com/,https://www.facebook.com/,https://www.tiktok.com/
